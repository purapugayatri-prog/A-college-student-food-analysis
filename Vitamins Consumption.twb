      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontsize='20'>Healthy Category</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='food_coded' name='federated.0zpbk0o1ntzf4s0zprt8o0tffva5' />
          </datasources>
          <datasource-dependencies datasource='federated.0zpbk0o1ntzf4s0zprt8o0tffva5'>
            <column caption='Health' datatype='string' name='[Calculation_0412335274598402]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [GPA]&gt;=3.0 THEN &quot;Healthy&quot;&#13;&#10;ElSE  &quot;UNhealthy&quot;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;UNhealthy&quot;' value='Unhealthy' />
              </aliases>
            </column>
            <column caption='Gender1' datatype='string' name='[Calculation_0412335275606019]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Gender] = 1 THEN &quot;Female&quot;&#13;&#10;ELSEIF [Gender] = 2 THEN &quot;Male&quot;&#13;&#10;ELSE  &quot;Unknown&quot;&#13;&#10;END' />
            </column>
            <column datatype='real' name='[GPA]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Gender]' role='measure' type='quantitative' />
            <column-instance column='[GPA]' derivation='Count' name='[cnt:GPA:qk]' pivot='key' type='quantitative' />
